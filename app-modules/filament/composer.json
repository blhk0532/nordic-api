{
	"name": "modules/filament",
	"description": "",
	"type": "library",
	"version": "1.0",
	"license": "proprietary",
    "require": {
        "filament/filament": "~5.0",
        "lartisan/filament-architect": "^1.0"
    },
	"repositories": [
        {
            "type": "path",
            "url": "plugins/cachethq/core",
            "options": {
                "symlink": true
            }
        }
	],
	"autoload": {
		"psr-4": {
			"Modules\\Filament\\": "src/",
			"Modules\\Filament\\Tests\\": "tests/",
			"Modules\\Filament\\Database\\Factories\\": "database/factories/",
			"Modules\\Filament\\Database\\Seeders\\": "database/seeders/"
		}
	},
	"minimum-stability": "dev",
    "prefer-stable": true,
	"extra": {
		"laravel": {
			"providers": [
				"Modules\\Filament\\Providers\\FilamentServiceProvider"
			],
			"dont-discover": [
                "cachethq/core"
            ]
		}
	}
}
