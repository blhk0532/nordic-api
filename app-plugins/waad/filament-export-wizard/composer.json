{
    "name": "waad/filament-export-wizard",
    "description": "Dynamic export wizard for Filament",
    "keywords": [
        "laravel",
        "filament",
        "export",
        "wizard"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "filament/filament": "^3.0|^4.0|^5.0",
        "spatie/laravel-package-tools": "^1.15"
    },
    "autoload": {
        "psr-4": {
            "Waad\\FilamentExportWizard\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Waad\\FilamentExportWizard\\FilamentExportWizardServiceProvider"
            ]
        }
    }
}
