{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/livewire-starter-kit",
    "type": "project",
    "description": "The official Laravel starter kit for Livewire.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "anish/text-input-entry": "*",
        "awcodes/overlook": "^4.0",
        "binarybuilds/filament-failed-jobs": "^2.1",
        "cachethq/core": "@dev",
        "caresome/filament-auth-designer": "^3.1",
        "cheesegrits/filament-google-maps": "@dev",
        "deldius/filament-user-field": "^1.1",
        "devletes/filament-pinnable-navigation": "^1.0",
        "devletes/filament-progress-bar": "^1.0",
        "eduardoribeirodev/filament-leaflet": "@dev",
        "eightynine/filament-excel-import": "dev-main",
        "fahiem/filament-pinpoint": "^1.1",
        "filament/filament": "^5.4",
        "gheith3/filament-relation-pages": "^1.0",
        "harvirsidhu/filament-cards": "^1.0",
        "internachi/modular": "^3.0",
        "joaopaulolndev/filament-edit-profile": "^3.0",
        "laravel/fortify": "^1.34",
        "laravel/framework": "^13.0",
        "laravel/octane": "^2.17",
        "laravel/sanctum": "^4.3",
        "laravel/tinker": "^3.0",
        "leandrocfe/filament-apex-charts": "^5.1",
        "livewire/flux": "^2.12.0",
        "livewire/livewire": "^4.1",
        "modules/filament": "*",
        "muazzam/slick-scrollbar": "dev-main",
        "nativephp/mobile": "^3.2",
        "spatie/laravel-google-calendar": "^3.8",
        "spatie/laravel-permission": "^7.3",
        "spatie/laravel-query-builder": "^7.2",
        "spiral/roadrunner-cli": "^2.6.0",
        "spiral/roadrunner-http": "^3.3.0",
        "wallacemartinss/filament-icon-picker": "^2.0",
        "zvizvi/user-fields": "^0.0.4"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "laravel/boost": "^2.0",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.27",
        "laravel/sail": "^1.53",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "lint": [
            "pint --parallel"
        ],
        "lint:check": [
            "pint --parallel --test"
        ],
        "ci:check": [
            "Composer\\Config::disableProcessTimeout",
            "@test"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@lint:check",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade",
            "@php artisan filament:assets"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan boost:update --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
	"minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "app-modules/*",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "app-plugins/cachethq/core",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "app-plugins/cheesegrits/filament-google-maps",
            "options": {
                "symlink": true
            }
        },
                {
            "type": "path",
            "url": "app-plugins/eightynine/filament-excel-import",
            "options": {
                "symlink": true
            }
        },
                {
            "type": "path",
            "url": "app-plugins/muazzam/slick-scrollbar",
            "options": {
                "symlink": true
            }
        }
    ]
}
